{
  "info": {
    "name": "Proyecto Integrador API",
    "description": "Pruebas de Postman para el proyecto de grafos híbrido.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [{"key": "Accept", "value": "application/json"}],
        "url": {"raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"]}
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
              "pm.test('Status is UP', function () { pm.expect(pm.response.json().status).to.eql('UP'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Solve Grafos",
      "request": {
        "method": "GET",
        "header": [{"key": "Accept", "value": "application/json"}],
        "url": {"raw": "{{baseUrl}}/solve", "host": ["{{baseUrl}}"], "path": ["solve"]}
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
              "pm.test('Respuesta exitosa', function () { pm.expect(pm.response.json().status).to.eql('success'); });"
            ]
          }
        }
      ]
    }
  ],
  "variable": [
    {"key": "baseUrl", "value": "http://localhost:8080"}
  ]
}